# EditorConfig is awesome: https://editorconfig.org
root = true

# -----------------------
# 通用配置
# -----------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# -----------------------
# Markdown
# -----------------------
[*.md]
trim_trailing_whitespace = false

# -----------------------
# JSON / YAML
# -----------------------
[*.json]
indent_size = 2

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

# -----------------------
# 配置文件（rc / lock）
# -----------------------
[*.{rc,conf}]
indent_size = 2

# -----------------------
# Shell
# -----------------------
[*.sh]
indent_size = 2

# -----------------------
# Makefile（必须用 tab）
# -----------------------
[Makefile]
indent_style = tab
